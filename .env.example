# =================================
# Logcat Analysis Agent Configuration
# =================================
# Copy this file to .env and configure your settings

# =================================
# Required Configuration
# =================================

# OpenAI API Key (Required for AI analysis features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Gemini API Key (Required for AI analysis features)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# =================================
# Optional Configuration
# =================================

# Default OpenAI Model
# Available: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible Base URL for local SLMs (Ollama/LM Studio/vLLM/NIM)
# Example: http://localhost:11434/v1
# Leave empty to use OpenAI Cloud
OPENAI_BASE_URL=

# OpenAI request timeout in milliseconds
# Default: 60000 when OPENAI_BASE_URL is set; otherwise 30000
OPENAI_TIMEOUT_MS=

# Analysis Profile
# Options: development, production, debug, performance, minimal
ANALYSIS_PROFILE=development

# Analysis Settings
ANALYSIS_WINDOW_SIZE=50
ANALYSIS_INTERVAL=5000
ANOMALY_THRESHOLD=0.7

# Feature Toggles
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_TREND_ANALYSIS=true
ENABLE_PROACTIVE_ANALYSIS=true

# Logging
LOG_LEVEL=info
DEBUG=false

# ADB Settings
LOG_BUFFERS=main,crash
LOG_PRIORITY=I

# Performance
MAX_BUFFER_SIZE=1000
AI_RATE_LIMIT=1

# Security
ENABLE_LOG_MASKING=true
