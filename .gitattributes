# Auto-detect text files and normalize line endings in the repo
* text=auto

# Enforce LF endings for source and config files across platforms
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Binary files - do not modify line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.zip  binary
